{
  "name": "lest",
  "version": "0.0.0",
  "private": true,
  "description": "LEST — Lightweight Easy Server Toolkit: a self-hosted web hosting control panel for Linux.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "dev:api": "npm -w @lest/api run dev",
    "dev:web": "npm -w @lest/web run dev",
    "db:push": "npm -w @lest/db run push",
    "db:seed": "npm -w @lest/db run seed"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
