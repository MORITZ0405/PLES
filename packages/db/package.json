  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@lest/config": "*",
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.38.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1"
  }
}
